# ========================================
# QuickBite Environment Variables
# ========================================
# Copy this file to .env and fill in your values
# NEVER commit your .env file to Git!

# ── Server ──────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────
# Option 1: MongoDB Atlas (FREE - recommended)
# Sign up at https://cloud.mongodb.com (no credit card needed)
# Create a free M0 cluster, then get your connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/quickbite?retryWrites=true&w=majority

# Option 2: Local MongoDB
# MONGODB_URI=mongodb://localhost:27017/quickbite

# ── JWT Authentication ──────────────────
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ── Client URL (for CORS) ──────────────
CLIENT_URL=http://localhost:5173
